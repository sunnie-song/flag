<view catchtap="checkboxChange" class="i-class i-checkbox">
    <i-cell iClass="i-checkbox-cell">
        <label>
            <radio checked="{{checked}}" class="i-checkbox-radio {{positionCls}}" color="{{checked?color:''}}" disabled="{{disabled}}" value="{{value}}"></radio>
            <view class="i-checkbox-title">{{value}}</view>
        </label>
    </i-cell>
</view>
