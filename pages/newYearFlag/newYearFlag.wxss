.count_down .count_box {
    width: 456rpx;
    height: 456rpx;
    position: absolute;
    top: 50%;
    margin-top: -228rpx;
    left: 147rpx;
}

.count_down .count_box .circle1 {
    width: 456rpx;
    height: 456rpx;
    border: 1rpx dashed #fff;
    border-radius: 400rpx;
    position: absolute;
    top: 0;
}

.count_down .count_box .circle2 {
    width: 382rpx;
    height: 382rpx;
    border: 1rpx dashed #fff;
    border-radius: 400rpx;
    position: absolute;
    top: 36rpx;
    left: 36rpx;
}

.count_down .count_box .circle3 {
    width: 310rpx;
    height: 310rpx;
    border: 2rpx solid #fff;
    border-radius: 400rpx;
    position: absolute;
    top: 73rpx;
    left: 73rpx;
}

.count_down .count_box .count_num1,.count_down .count_box .count_num2,.count_down .count_box .count_num3 {
    width: 134rpx;
    height: 225rpx;
    background: url(https://6f6e-online-e879a3-1258444488.tcb.qcloud.la/newYearFlag/settings/count_num1.png) -318rpx -10rpx no-repeat;
    background-size: 462rpx 245rpx;
    position: absolute;
    top: 115rpx;
    left: 162rpx;
    opacity: 0;
    -webkit-transform: scale(.7);
    -webkit-transform-origin: 50% 50%;
    -webkit-transition: all linear .3s;
}

.count_down .count_box .count_num1.num_show,.count_down .count_box .count_num2.num_show,.count_down .count_box .count_num3,.count_down .count_box .count_num3.num_show {
    opacity: 1;
}

.count_down .count_box .count_num2 {
    background-position: -164rpx -10rpx;
}

.count_down .count_box .count_num1 {
    background-position: -10rpx -10rpx;
}

.count_down .count_box .count_num1.num_hide,.count_down .count_box .count_num2.num_hide,.count_down .count_box .count_num3.num_hide {
    -webkit-transform: scale(1);
    opacity: 0;
}

.count_down .count_box .bar {
    width: 14rpx;
    height: 155rpx;
    position: absolute;
    bottom: 228rpx;
    left: 221rpx;
    transform-origin: 50% 100%;
}

.count_down .count_box .bar.bar_ani {
    animation: bar 1.5s linear;
}

.count_down .count_box .bar .bar_line {
    width: 0;
    height: 100%;
    border-left: 1rpx dashed #fff;
    position: absolute;
    left: 7rpx;
    top: 0;
}

.count_down .count_box .bar .top_circle {
    width: 14rpx;
    height: 14rpx;
    position: absolute;
    background: #fff;
    border-radius: 20rpx;
    top: -7rpx;
    left: 0;
}

.count_down .circles_box {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
}

.count_down .circles_box>div {
    position: absolute;
    width: 10rpx;
    height: 10rpx;
    border-radius: 10rpx;
    border: 1rpx solid #fff;
}

.result {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    display: none;
    z-index: 100;
    overflow-y: scroll;
}

.result .bottom_show {
    position: absolute;
    top: 0;
    width: 100%;
    height: 100%;
}

.result .firework {
    position: absolute;
    top: 0;
    width: 750rpx;
    height: 100%;
    animation: firework 3s linear;
    background-size: 750rpx 1334rpx;
}

.result .saved_guide {
    display: block;
    width: 750rpx;
    height: 100rpx;
    position: fixed;
    background: #ececec;
    bottom: 0;
    font-size: 30rpx;
    line-height: 100rpx;
    text-align: center;
    z-index: 1000;
}



 

 

