@-webkit-keyframes s {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
    }
}

@keyframes s {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
    }
}

@-webkit-keyframes arrow {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
        bottom: 420rpx;
    }
}

@keyframes arrow {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
        bottom: 420rpx;
    }
}

@-webkit-keyframes arrowX {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
        bottom: 520rpx;
    }
}

@keyframes arrowX {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
        bottom: 520rpx;
    }
}

@-webkit-keyframes read {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
    }
}

@keyframes read {
    0%,to {
        opacity: 1;
    }

    50% {
        opacity: 0;
    }
}

@-webkit-keyframes ruler {
    0% {
        opacity: 0;
        -webkit-transform: translate3d(-141rpx,0,0);
    }

    to {
        opacity: 1;
        -webkit-transform: translate3d(59rpx,0,0);
    }
}

@keyframes ruler {
    0% {
        opacity: 0;
        -webkit-transform: translate3d(-141rpx,0,0);
    }

    to {
        opacity: 1;
        -webkit-transform: translate3d(59rpx,0,0);
    }
}

@-webkit-keyframes bar {
    0%,to {
        height: 0rpx;
        -webkit-transform: rotate(0deg);
    }

    50% {
        height: 228rpx;
        -webkit-transform: rotate(360deg);
    }
}

@keyframes bar {
    0%,to {
        height: 0rpx;
        -webkit-transform: rotate(0deg);
    }

    50% {
        height: 228rpx;
        -webkit-transform: rotate(360deg);
    }
}

@-webkit-keyframes changeRotate {
    0%,to {
        -webkit-transform: rotate(0deg);
    }

    100% {
        -webkit-transform: rotate(180deg);
    }
}

@keyframes changeRotate {
    0%,to {
        -webkit-transform: rotate(0deg);
    }

    100% {
        -webkit-transform: rotate(180deg);
    }
}

